                "content": "<style>@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Outfit:wght@300;400;500;600&display=swap');:root{--sc-brn:#2C1E1A;--sc-grn:#7FA68E;--sc-bg:#FDFCF9;--sc-lne:rgba(44,30,26,0.09);--sc-muted:#999;}*{box-sizing:border-box;margin:0;padding:0;}#soco-app{font-family:'Outfit',sans-serif;color:var(--sc-brn);background:var(--sc-bg);max-width:640px;margin:0 auto;min-height:100vh;padding-bottom:120px;}@media (max-width:1024px){.header,.footer{display:none !important;}#soco-app{padding-top:0;}.sc-back-btn{display:flex !important;}}.sc-hero{height:26vh;overflow:hidden;position:relative;}.sc-hero img{width:100%;height:100%;object-fit:cover;}.sc-back-btn{position:absolute;top:16px;left:16px;width:36px;height:36px;background:rgba(255,255,255,0.2);backdrop-filter:blur(10px);border-radius:50%;display:none;align-items:center;justify-content:center;color:#fff;z-index:100;border:1px solid rgba(255,255,255,0.3);text-decoration:none;transition:all .2s;}.sc-back-btn:active{transform:scale(0.9);background:rgba(255,255,255,0.4);}.sc-hero-title{position:absolute;bottom:18px;left:0;right:0;text-align:center;color:#fff;font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:700;text-shadow:0 2px 16px rgba(0,0,0,0.55);letter-spacing:.04em;}.sc-hero-sub{position:absolute;bottom:7px;left:0;right:0;text-align:center;color:rgba(255,255,255,0.7);font-size:0.62rem;letter-spacing:3px;text-transform:uppercase;font-weight:500;}.sc-cat-nav{position:sticky;top:0;background:var(--sc-bg);z-index:50;display:flex;gap:6px;padding:10px 16px;overflow-x:auto;border-bottom:1px solid var(--sc-lne);scrollbar-width:none;}.sc-cat-nav::-webkit-scrollbar{display:none;}.cat-btn{padding:5px 16px;border:1.5px solid var(--sc-lne);border-radius:2px;background:transparent;font-size:0.72rem;font-weight:600;cursor:pointer;color:var(--sc-muted);transition:all .2s;white-space:nowrap;letter-spacing:.04em;text-transform:uppercase;}.cat-btn.on,.cat-btn:hover{border-color:var(--sc-brn);color:var(--sc-brn);background:#fff;}.sc-menu{padding:0 16px 16px;}.sc-cat-block{margin-bottom:8px;}.sc-cat-title{font-family:'Playfair Display',serif;font-size:0.9rem;font-style:italic;color:var(--sc-muted);padding:20px 0 10px;letter-spacing:.06em;border-bottom:1px solid var(--sc-lne);margin-bottom:4px;}.prod-row{display:flex;gap:15px;align-items:center;padding:15px 0;border-bottom:1px solid var(--sc-lne);transition:all .35s ease;}.prod-row.active{background:rgba(127,166,142,0.03);margin-left:-16px;margin-right:-16px;padding-left:16px;padding-right:16px;}.prod-txt{flex:1;min-width:0;}.prod-nm{font-weight:600;font-size:0.97rem;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}.prod-ds{font-size:0.76rem;color:var(--sc-muted);line-height:1.45;margin-bottom:5px;}.prod-pr{font-weight:500;font-size:0.83rem;color:var(--sc-brn);opacity:.65;}.sc-item-ctrl{display:flex;flex-direction:column;align-items:center;gap:8px;min-width:60px;}.sc-select{width:22px;height:22px;border-radius:50%;border:1.8px solid var(--sc-brn);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;}.sc-select.on{background:var(--sc-grn);border-color:var(--sc-grn);color:#fff;}.sc-select svg{display:none;width:13px;height:13px;}.sc-select.on svg{display:block;}.prod-qty-nav{display:none;align-items:center;gap:8px;background:#fff;border:1px solid var(--sc-lne);border-radius:4px;padding:2px;}.prod-row.active .prod-qty-nav{display:flex;}.qty-btn-s{width:20px;height:20px;border:none;background:none;font-weight:600;cursor:pointer;color:var(--sc-brn);}.qty-val-s{font-size:0.75rem;font-weight:700;min-width:12px;text-align:center;}.prod-img{width:68px;height:68px;border-radius:8px;object-fit:cover;flex-shrink:0;}.prod-img-ph{width:68px;height:68px;border-radius:8px;background:rgba(44,30,26,0.04);flex-shrink:0;}.sc-overlay{display:none;position:fixed;inset:0 0 80px 0;background:rgba(20,12,10,0.45);backdrop-filter:blur(6px);z-index:300;}.sc-overlay.show{display:block;}.sc-chat{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(110%);width:100%;max-width:640px;background:#fff;border-radius:18px 18px 0 0;z-index:400;display:flex;flex-direction:column;max-height:72vh;transition:transform .38s cubic-bezier(.32,0,.2,1);box-shadow:0 -8px 40px rgba(0,0,0,0.1);}.sc-chat.open{transform:translateX(-50%) translateY(0);}.sc-chat-hd{display:flex;align-items:center;justify-content:space-between;padding:15px 20px 13px;border-bottom:1px solid var(--sc-lne);flex-shrink:0;}.sc-chat-nm{font-family:'Playfair Display',serif;font-size:1.05rem;display:flex;align-items:center;gap:8px;}.sc-chat-dot{width:7px;height:7px;border-radius:50%;background:var(--sc-grn);animation:pulse 2s infinite;}.sc-chat-close{background:none;border:1px solid var(--sc-lne);border-radius:3px;padding:4px 14px;font-size:0.72rem;cursor:pointer;color:var(--sc-muted);font-family:'Outfit',sans-serif;letter-spacing:.04em;}.sc-chat-close:hover{border-color:var(--sc-brn);color:var(--sc-brn);}.sc-msgs{flex:1;overflow-y:auto;padding:16px 20px 55px;display:flex;flex-direction:column;gap:10px;scrollbar-width:thin;scrollbar-color:rgba(44,30,26,.1) transparent;}.msg{display:flex;flex-direction:column;max-width:88%;}.msg-m{align-self:flex-start;}.msg-u{align-self:flex-end;}.msg-lbl{font-size:0.56rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--sc-grn);margin-bottom:4px;}.msg-body{font-size:0.875rem;line-height:1.55;color:var(--sc-brn);border-left:2px solid var(--sc-lne);padding-left:10px;}.msg-u-body{border-left:none;border-right:2px solid var(--sc-lne);padding-left:0;padding-right:10px;color:var(--sc-muted);font-style:italic;text-align:right;}.msg-typing{align-self:flex-start;display:flex;gap:5px;padding:10px 12px;border-left:2px solid var(--sc-lne);}.typing-dot{width:5px;height:5px;border-radius:50%;background:var(--sc-muted);animation:bounce .8s infinite;}.typing-dot:nth-child(2){animation-delay:.15s;}.typing-dot:nth-child(3){animation-delay:.3s;}.msg-card{display:flex;gap:12px;align-items:center;border:1px solid var(--sc-lne);border-radius:10px;padding:11px 14px;background:var(--sc-bg);margin-top:2px;max-width:95%;}.msg-card img{width:52px;height:52px;border-radius:7px;object-fit:cover;flex-shrink:0;}.msg-card-nm{font-weight:700;font-size:0.9rem;margin-bottom:2px;}.msg-card-ds{font-size:0.71rem;color:var(--sc-muted);margin-bottom:4px;line-height:1.4;}.msg-card-pr{font-weight:700;color:var(--sc-grn);font-size:0.88rem;}.msg-card-btn{background:var(--sc-brn);color:#fff;border:none;margin-top:8px;padding:6px 10px;border-radius:4px;font-size:0.62rem;font-weight:600;text-transform:uppercase;cursor:pointer;transition:all .2s;letter-spacing:.04em;}.msg-card-btn:hover{background:var(--sc-grn);}.qty-ctrl{display:flex;align-items:center;gap:10px;margin-top:8px;}.qty-btn{width:22px;height:22px;border-radius:4px;border:1px solid var(--sc-lne);background:#fff;color:var(--sc-brn);cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:14px;}.qty-val{font-size:0.8rem;font-weight:700;min-width:14px;text-align:center;}.cart-btn-dock{background:var(--sc-brn);color:#fff;border:none;padding:8px 18px;border-radius:8px;font-size:0.75rem;font-weight:600;cursor:pointer;box-shadow:0 4px 15px rgba(0,0,0,0.15);transition:all 0.2s;white-space:nowrap;}.cart-btn-dock:active{transform:scale(0.95);}.sc-list-view{display:none;position:fixed;inset:0;background:#fff;z-index:1000;flex-direction:column;animation:slideUp .3s ease-out;}.sc-list-view.show{display:flex;}.sc-list-hd{padding:20px;border-bottom:1px solid var(--sc-lne);display:flex;justify-content:space-between;align-items:center;background:var(--sc-bg);}.sc-list-hd h2{font-family:'Playfair Display',serif;font-size:1.4rem;}.sc-list-body{flex:1;overflow-y:auto;padding:20px;}.ticket-row{display:flex;flex-direction:column;padding:15px 0;border-bottom:1px dashed var(--sc-lne);}.tr-top{display:flex;justify-content:space-between;align-items:flex-start;}.tr-name{font-weight:700;font-size:1rem;}.tr-price{font-weight:700;color:var(--sc-grn);font-size:1rem;}.tr-details{display:flex;align-items:center;gap:12px;margin-top:8px;color:var(--sc-muted);font-size:0.8rem;}.tr-obs{margin-top:8px;font-style:italic;color:#666;font-size:0.75rem;background:rgba(44,30,26,0.03);padding:6px 10px;border-radius:4px;border-left:2px solid var(--sc-brn);}.tr-edit-btn{background:none;border:1px solid var(--sc-lne);padding:4px 10px;border-radius:4px;font-size:0.7rem;cursor:pointer;color:var(--sc-brn);display:flex;align-items:center;gap:4px;font-weight:600;}.sc-list-total{padding:25px 20px;border-top:2px solid var(--sc-brn);display:flex;justify-content:space-between;font-weight:800;font-size:1.2rem;background:var(--sc-bg);}.sc-edit-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);backdrop-filter:blur(3px);z-index:1100;align-items:center;justify-content:center;padding:20px;}.sc-edit-modal.show{display:flex;}.edit-card{background:#fff;width:100%;max-width:340px;padding:24px;border-radius:16px;box-shadow:0 12px 40px rgba(0,0,0,0.3);}.edit-card h4{margin-bottom:15px;font-family:'Playfair Display',serif;font-size:1.2rem;}.edit-card p{font-size:0.8rem;color:var(--sc-muted);margin-bottom:12px;}.edit-card textarea{width:100%;height:90px;padding:12px;border:1px solid var(--sc-lne);border-radius:8px;font-family:inherit;font-size:0.88rem;resize:none;outline:none;background:#f9f9f9;}.edit-card textarea:focus{border-color:var(--sc-brn);}.edit-card .btn-row{display:flex;gap:10px;margin-top:20px;}.btn-save{flex:1;background:var(--sc-brn);color:#fff;border:none;padding:12px;border-radius:8px;font-size:0.85rem;font-weight:600;cursor:pointer;}.btn-del{background:#fadde1;color:#b00;border:none;padding:12px;border-radius:8px;font-size:0.85rem;font-weight:600;cursor:pointer;}.sc-dock{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:640px;z-index:500;background:var(--sc-bg);border-top:1px solid var(--sc-lne);padding:10px 16px 20px;}.sc-dock-top{display:flex;align-items:center;gap:10px;margin-bottom:10px;padding:0 4px;}.sc-dock-inner{display:flex;align-items:center;gap:10px;background:#F5F3EF;border-radius:8px;padding:10px 14px;box-shadow:inset 0 1px 3px rgba(0,0,0,0.04);}.sc-input{flex:1;border:none;background:transparent;outline:none;font-size:0.92rem;font-family:'Outfit',sans-serif;color:var(--sc-brn);}.sc-input::placeholder{color:#c0b8b0;}.sc-send{background:none;border:none;cursor:pointer;opacity:.45;padding:4px;color:var(--sc-brn);transition:opacity .2s;flex-shrink:0;}.sc-send:hover,.sc-send:focus{opacity:1;}@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}</style><div id='soco-app'><div class='sc-hero'><a href='index.html' class='sc-back-btn' aria-label='Volver al inicio'><svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M19 12H5'/><path d='M12 19l-7-7 7-7'/></svg></a><img src='/themes/socola/assets/hero.png' onerror='this.src=\"https://images.unsplash.com/photo-1447933601403-0c6688de566e?w=900\"' alt='Socolá'><div class='sc-hero-title'>Socolá</div><div class='sc-hero-sub'>Especialidad &amp; Repostería</div></div><div class='sc-cat-nav' id='cat-nav'></div><div class='sc-menu' id='menu-list'></div><div class='sc-overlay' id='overlay' onclick='closeChat()'></div><div class='sc-chat' id='chat-panel'><div class='sc-chat-hd'><span class='sc-chat-nm'><span class='sc-chat-dot'></span>Maître Socolá</span><button class='sc-chat-close' onclick='closeChat()'>Cerrar</button></div><div class='sc-msgs' id='msg-area'></div></div><div class='sc-list-view' id='cart-view'><div class='sc-list-hd'><h2>Mi Pedido</h2><button class='sc-chat-close' onclick='closeCart()'>Cerrar</button></div><div class='sc-list-body' id='cart-items-list'></div><div class='sc-list-total'><span>Total</span><span id='cart-total-val'>0,00 €</span></div></div><div class='sc-edit-modal' id='edit-modal'><div class='edit-card'><h4>Editar Producto</h4><p id='edit-prod-name'></p><div class='qty-ctrl'><button class='qty-btn' onclick='changeEditQty(-1)'>-</button><span class='qty-val' id='edit-qty-val'>1</span><button class='qty-btn' onclick='changeEditQty(1)'>+</button></div><textarea id='edit-obs' placeholder='Observaciones (ej: leche de avena, sin azúcar...)'></textarea><div class='btn-row'><button class='btn-del' onclick='removeFromCart()'>Eliminar</button><button class='btn-save' onclick='saveEdit()'>Guardar</button></div></div></div><div class='sc-dock'><div class='sc-dock-top' id='sc-dock-top'><div id='main-service-btns' style='display:flex;gap:8px;'></div><button id='cart-btn' class='cart-btn-dock' onclick='openCart()'>Mi lista</button></div><div class='sc-dock-inner'><input type='text' id='chat-input' class='sc-input' placeholder='¿Qué me recomienda hoy?'><button class='sc-send' onclick='sendMsg()' aria-label='Enviar'><svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'><path d='M22 2L11 13'/><path d='M22 2l-7 20-4-9-9-4 20-7z'/></svg></button></div></div></div><script src='/js/socola-carta.js'></script>"
