GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# Dominio público base para URLs de subdominio de cada local.
# En producción: mylocal.es  → carta pública en <slug>.mylocal.es/carta
# En local (localhost): no se usa — se usa window.location.origin automáticamente.
VITE_PUBLIC_DOMAIN=mylocal.es
