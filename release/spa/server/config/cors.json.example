{
    "_doc": "Whitelist de orígenes CORS permitidos. Copia a cors.json. En dev añade http://localhost:5173. En prod, SOLO los dominios propios (ej: https://mylocal.es). Las acciones públicas se definen en index.php (PUBLIC_ACTIONS) — no en este fichero.",
    "allowed_origins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173"
    ],
    "allow_credentials": true
}
