{
    "key": "google-drive",
    "name": "Google Drive (Atomic)",
    "version": "1.2.0",
    "type": "HYBRID",
    "capabilities": [
        "listFiles",
        "createFolder",
        "uploadFile",
        "export",
        "trash"
    ],
    "endpoints": {
        "list": "/api/google/drive/v3/files",
        "upload": "/api/google/drive/upload/v3/files"
    }
}