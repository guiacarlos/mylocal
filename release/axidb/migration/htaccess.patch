# AxiDB Fase 5 - patch propuesto al .htaccess de Socola
#
# OBJETIVO: anadir un alias retrocompat para que /axidb/api/ sea reachable
# DEJANDO INTACTA la regla existente de /acide/ -> CORE/. Asi durante el
# periodo de coexistencia (>= 1 semana) ambos endpoints funcionan, y el
# rollback es de una linea.
#
# COMO APLICARLO:
#   1. Backup primero:    cp .htaccess .htaccess.bak.$(date +%F)
#   2. Edita .htaccess y aplica el bloque de abajo en la posicion indicada.
#   3. Sube al hosting o reinicia Apache (no es necesario en .htaccess pero
#      conviene un curl de prueba).
#
# COMO REVERTIR (<5 min):
#   cp .htaccess.bak.<fecha> .htaccess
#
# VERIFICACION POST-PATCH (gates §8 del plan):
#   curl -s http://socola/index.html | grep -q "page-home" && echo OK
#   curl -s -X POST http://socola/axidb/api/axi.php \
#     -H 'Content-Type: application/json' -d '{"op":"ping"}' | grep success
#   curl -s -X POST http://socola/acide/index.php \
#     -H 'Content-Type: application/json' -d '{"action":"list_products"}' | head -c 200

# ============================================================
# UBICACION: tras la linea 11 del .htaccess actual.
# Linea 11 actual:
#     RewriteRule ^acide/(.*)$ CORE/$1 [END,QSA]
# ============================================================

# AGREGAR INMEDIATAMENTE DESPUES (no quitar la linea 11):

    # AxiDB Fase 5: gateway nuevo. Tiene su propio entry point en
    # /axidb/api/axi.php. Esta regla solo sirve para que NO se reescriba
    # accidentalmente por reglas posteriores (END corta el flujo).
    RewriteRule ^axidb/api/(.*)$ axidb/api/$1 [END,QSA]

    # AxiDB Fase 5: si Socola SPA o un cliente externo llama todavia a
    # /acide/index.php, sigue funcionando (regla de arriba). Tras 1+
    # semana de coexistencia sin errores, opcional: redirige a /axidb/api/
    # con esta linea (descomenta y comenta la linea 11 original):
    #
    #     RewriteRule ^acide/(.*)$ axidb/api/$1 [END,QSA]

# ============================================================
# AVANZADO (NO aplicar todavia): si en el futuro se borra el legacy
# CORE/index.php por completo, basta con cambiar la linea 11 a:
#
#     RewriteRule ^acide/(.*)$ axidb/api/$1 [END,QSA]
#
# Este es el "swap atomico" del plan §5.4. Hacer SOLO tras:
#   - Pasar todos los gates §8.
#   - Backup completo del FS y snapshot AxiDB (axi backup create).
#   - Periodo de coexistencia >= 1 semana sin errores reportados.
# ============================================================
