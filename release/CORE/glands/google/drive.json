{
    "key": "google-drive",
    "name": "Google Drive Gland",
    "version": "1.0.0",
    "type": "HYBRID",
    "provider": "Google",
    "capabilities": [
        "storage",
        "file-management",
        "sharing"
    ],
    "endpoints": {
        "list": "/api/drive/list",
        "upload": "/api/drive/upload",
        "download": "/api/drive/download",
        "sync": "/api/drive/sync"
    },
    "schema": {
        "files": "array",
        "quota": "object"
    },
    "ai_hints": {
        "context": "Gestión de archivos en la nube con persistencia local de metadatos.",
        "operations": {
            "get_files": "Lista archivos con filtros de tipo.",
            "backup_acide": "Sube un snapshot de ACIDE.php a una carpeta segura en Drive."
        }
    }
}