{
    "name": "OPTIONS",
    "version": "1.0.0",
    "description": "Source of truth de configuracion. API keys, modelos, branding, billing, fiscal — todo en un solo sitio con namespaces.",
    "type": "core",
    "exposes": [
        "OPTIONS\\OptionsConnector"
    ],
    "actions": [
        "options_get",
        "options_set",
        "options_get_namespace",
        "options_set_namespace",
        "options_list_namespaces"
    ],
    "storage": {
        "collection": "options",
        "path": "STORAGE/options/<namespace>.json"
    },
    "namespaces": {
        "ai": "API key de Gemini, modelo por defecto, modelo de vision",
        "branding": "Logo, paleta, nombre publico",
        "billing": "Stripe keys, planes activos",
        "fiscal": "Verifactu/TicketBAI"
    }
}
