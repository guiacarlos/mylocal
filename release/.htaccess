# 🏛️ ACIDE SOBERANO - REGLAS DE ORQUESTACIÓN v14.0
Options -Indexes
Options +FollowSymLinks
DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 0. REDIRECCION HTTP A HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 1. API SOBERANA — prioridad absoluta, debe ir ANTES del bloqueo de seguridad
    # [END] previene que Apache reinicie las reglas con la URL reescrita (CORE/index.php)
    RewriteRule ^acide/(.*)$ CORE/$1 [END,QSA]

    # 🛡️ BLOQUEO DE ACCESO DIRECTO A DIRECTORIOS SENSIBLES
    # Solo aplica a peticiones externas (REDIRECT_STATUS vacío = petición inicial)
    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^(CORE|STORAGE|CAPABILITIES|STORE)(/.*)?$ - [F,L]

    # 1.07 MEDIA — normaliza /media/ (lowercase) → /MEDIA/ (uppercase, Linux case-sensitive)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^media(/.*)?$ MEDIA$1 [L]

    # 4. CARTA PUBLICA — /carta/{slug} y /carta/{slug}/{mesa}
    RewriteRule ^carta/[a-z0-9\-]+(/[a-z0-9\-]+)?$ carta.html [L]

    # 5. Google OAuth2 callback — enrutado antes del fallback SPA
    RewriteRule ^server/gcal_callback\.php$ spa/server/gcal_callback.php [L]

    # 6. FALLBACK Web Publica SPA — RewriteBase omitido (funciona en raiz y subdirectorio)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]
</IfModule>

# SECURITY & MIME TYPES
AddType application/javascript .js
AddType text/css .css
AddType font/woff2 .woff2
AddType font/ttf .ttf
AddType image/webp .webp
AddType image/jpeg .jpg .jpeg
AddType image/png .png
AddType image/gif .gif
