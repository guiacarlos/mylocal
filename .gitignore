# ── Logs ──────────────────────────────────────────────────────
*.log
php_errors.log

# ── Datos de sesión / usuarios (sensibles) ─────────────────────
spa/server/data/sessions/
spa/server/data/users/
spa/server/data/_rl/
spa/server/data/ocr_uploads/
spa/server/data/mesas/
spa/server/data/zonas/
spa/server/data/cartas/
spa/server/data/carta_categorias/
spa/server/data/carta_productos/
spa/server/data/locales/
spa/server/data/local/
release/spa/server/data/sessions/
release/spa/server/data/users/
release/spa/server/data/_rl/
release/spa/server/data/ocr_uploads/
release/spa/server/data/mesas/
release/spa/server/data/zonas/
release/spa/server/data/cartas/
release/spa/server/data/carta_categorias/
release/spa/server/data/carta_productos/
release/spa/server/data/locales/
release/spa/server/data/local/
STORAGE/sessions/
STORAGE/revisions/

# ── Configuración con SECRETOS — NO commitear NUNCA ────────────
# Google escanea repos publicos y REVOCA cualquier key que aparezca
# (lo aprendimos por las malas el 2026-05-05). Lo unico que se sube
# son los .example sin valores reales.
spa/server/config/gemini.json
spa/server/config/gemini_settings.json
spa/server/config/revolut.json
spa/server/config/auth.json
spa/server/config/cors.json
# config.json en la raiz del proyecto (legacy: tenia credenciales antiguas).
# El config del tenant nuevo vive en spa/public/config.json y SI se versiona
# por defecto; cada despliegue lo regenera el AppBootstrap.
/config.json

# OPTIONS - source of truth de configuracion (api keys, stripe, etc).
# Solo se versiona el .example (sin secretos). El .json real queda local.
STORAGE/options/*.json
!STORAGE/options/*.example
release/STORAGE/options/*.json
!release/STORAGE/options/*.example
STORAGE/config/agente_settings.json
release/STORAGE/config/agente_settings.json
STORAGE/config/gemini_settings.json
release/STORAGE/config/gemini_settings.json
release/spa/server/config/gemini.json
release/spa/server/config/auth.json
release/spa/server/config/cors.json
release/spa/server/config/revolut.json

# ── Dependencias ───────────────────────────────────────────────
node_modules/
vendor/

# ── Build / Release generado ───────────────────────────────────
release_new/

# ── Archivos del sistema ───────────────────────────────────────
.DS_Store
Thumbs.db

# ── TypeScript build cache ─────────────────────────────────────
spa/tsconfig.tsbuildinfo
spa/tsconfig.node.tsbuildinfo
spa/vite.config.d.ts
spa/vite.config.js

# ── Scripts de prueba temporales ───────────────────────────────
test_*.php
# excepciones: tests de integracion load-bearing (Ola E)
!spa/server/tests/test_login.php
!release/spa/server/tests/test_login.php
!spa/server/tests/test_citas.php
!spa/server/tests/test_crm.php
!spa/server/tests/test_notif.php

# ── Estado local del agente / material de trabajo personal ─────
.claude/
claude/recetascocina/
claude/snapshots/

# ── Bundles de Vite (regenerados en cada build, su hash cambia) ─
# Las fuentes (.ttf) si se versionan: cambian poco y el nombre
# con hash garantiza cache-busting cuando se actualizan.
release/assets/index-*.js
release/assets/index-*.css
