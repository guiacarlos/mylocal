{
    "id": "hosteleria",
    "name": "MyLocal · Hosteleria",
    "version": "1.0.0",
    "description": "Modulo vertical para hosteleria: carta digital, mesas QR, TPV y pedidos en tiempo real.",
    "requires_capabilities": [
        "CARTA",
        "QR",
        "TPV",
        "PRODUCTS",
        "OCR",
        "PDFGEN",
        "AGENTE_RESTAURANTE"
    ],
    "public_routes": [
        { "path": "/carta",                       "component": "Carta" },
        { "path": "/carta/:zonaSlug",             "component": "Carta" },
        { "path": "/carta/:zonaSlug/:mesaSlug",   "component": "Carta" }
    ],
    "raw_routes": [
        { "path": "/mesa/:slug", "component": "MesaQR" }
    ],
    "staff_routes": [
        { "path": "/sistema/tpv/*", "component": "TPV" }
    ],
    "crumb_labels": {
        "carta":     "Carta",
        "mesas":     "Mesas",
        "pedidos":   "Pedidos",
        "importar":  "Importar",
        "productos": "Productos",
        "pdf":       "PDF",
        "web":       "Web"
    },
    "public_link": {
        "route": "/carta",
        "label": "Ver mi carta",
        "title": "Abre tu carta pública en una pestaña nueva"
    },
    "dashboard_nav": [
        { "to": "/dashboard/carta",   "label": "Carta",   "icon": "Book" },
        { "to": "/dashboard/mesas",   "label": "Mesas",   "icon": "Armchair" },
        { "to": "/dashboard/pedidos", "label": "Pedidos", "icon": "Bell" }
    ],
    "dashboard_routes": [
        { "path": "carta/*", "component": "CartaPage", "children": [
            { "index": true, "redirect": "importar" },
            { "path": "importar",   "component": "CartaImportarPage" },
            { "path": "productos",  "component": "CartaProductosPage" },
            { "path": "pdf",        "component": "CartaPdfPage" },
            { "path": "web",        "component": "CartaWebPage" }
        ]},
        { "path": "mesas",   "component": "MesasPage" },
        { "path": "pedidos", "component": "PedidosPage" }
    ]
}
