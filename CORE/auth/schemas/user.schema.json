{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "User Schema",
    "description": "Esquema de usuario para ACIDE Auth System",
    "type": "object",
    "required": [
        "id",
        "email",
        "password_hash",
        "role",
        "created_at"
    ],
    "properties": {
        "id": {
            "type": "string",
            "description": "UUID único del usuario",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "email": {
            "type": "string",
            "format": "email",
            "description": "Email único del usuario (usado para login)"
        },
        "password_hash": {
            "type": "string",
            "description": "Hash Argon2id/Bcrypt de la contraseña"
        },
        "name": {
            "type": "string",
            "description": "Nombre completo del usuario",
            "minLength": 1,
            "maxLength": 255
        },
        "role": {
            "type": "string",
            "enum": [
                "superadmin",
                "admin",
                "editor",
                "viewer"
            ],
            "description": "Rol del usuario en el sistema"
        },
        "status": {
            "type": "string",
            "enum": [
                "active",
                "inactive",
                "suspended"
            ],
            "default": "active",
            "description": "Estado de la cuenta"
        },
        "metadata": {
            "type": "object",
            "description": "Metadatos adicionales del usuario",
            "properties": {
                "avatar": {
                    "type": "string"
                },
                "phone": {
                    "type": "string"
                },
                "company": {
                    "type": "string"
                }
            }
        },
        "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Fecha de creación"
        },
        "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Última actualización"
        },
        "last_login": {
            "type": "string",
            "format": "date-time",
            "description": "Último inicio de sesión"
        }
    }
}